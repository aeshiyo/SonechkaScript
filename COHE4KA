            -- Анимация масштабирования меню при открытии
            MainMenu.Size = UDim2.new(0, 700, 0, 400)
            TweenService:Create(MainMenu, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
