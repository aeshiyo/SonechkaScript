    frames = frames + 1
end)

task.spawn(function()
    while task.wait(1) do
        local ping = math.random(20, 85) -- Имитация или можно получить реальный пинг через Stats
        StatsText.Text = string.format("PING: %dms   |   FPS: %d", ping, frames)
        frames = 0
    end
end)

