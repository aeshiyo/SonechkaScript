Sidebar.Parent = MainMenu

local Tabs = {"AIMBOT", "WALLHACK", "ESP", "MISC", "SETTINGS"}
for i, tabName in ipairs(Tabs) do
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(1, 0, 0, 40)
    TabBtn.Position = UDim2.new(0, 0, 0, (i-1)*45 + 10)
    TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Font = Enum.Font.Rajdhani
    TabBtn.Text = "  " .. tabName
    TabBtn.TextColor3 = Color3.fromRGB(139, 146, 165)
    TabBtn.TextSize = 18
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.Parent = Sidebar

    -- Эффект при наведении
    TabBtn.MouseEnter:Connect(function()
        TweenService:Create(TabBtn, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 0, 127)}):Play()
    end)
    TabBtn.MouseLeave:Connect(function()
        TweenService:Create(TabBtn, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(139, 146, 165)}):Play()
    end)
end

